#!/usr/bin/env bash
set -euo pipefail

app_name="${0##*/}"

fail() {
  echo "$app_name: $*" >&2
  exit 2
}

expand_path() {
  case "$1" in
    ~) printf '%s\n' "$HOME" ;;
    ~/*) printf '%s\n' "$HOME/${1#~/}" ;;
    *) printf '%s\n' "$1" ;;
  esac
}

canonical_dir() {
  (
    cd "$1"
    pwd -P
  )
}

is_path() {
  case "$1" in
    .* | ~* | /* | */*) return 0 ;;
    *) return 1 ;;
  esac
}

find_profile_dir() {
  local name="$1"
  local dir
  local candidate

  dir="$(pwd -P)"

  while true; do
    for candidate in "$dir/.agents/$name" "$dir/.agents/profiles/$name"; do
      [[ -d "$candidate" ]] && canonical_dir "$candidate" && return 0
    done

    [[ "$dir" == "/" || -e "$dir/.git" ]] && break
    dir="$(dirname "$dir")"
  done

  candidate="$HOME/.pi/agent/profiles/$name"
  [[ -d "$candidate" ]] && canonical_dir "$candidate"
}

resolve_profile_dir() {
  local arg="$1"
  local path

  if is_path "$arg"; then
    path="$(expand_path "$arg")"
    [[ -d "$path" ]] || fail "profile dir not found: $arg"
    canonical_dir "$path"
    return
  fi

  find_profile_dir "$arg" || fail "profile not found: $arg"
}

link_auth() {
  local profile_dir="$1"
  local source_auth="${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}/auth.json"
  local target_auth="$profile_dir/auth.json"

  [[ -e "$target_auth" || -L "$target_auth" ]] && return 0
  [[ -e "$source_auth" || -L "$source_auth" ]] || return 0

  ln -s "$source_auth" "$target_auth"
}

main() {
  [[ $# -ge 1 ]] || fail "usage: $app_name <profile-name|profile-dir> [pi args...]"

  local profile_dir
  profile_dir="$(resolve_profile_dir "$1")"
  link_auth "$profile_dir"

  export PI_CODING_AGENT_DIR="$profile_dir"
  export PI_OFFLINE=true

  shift
  exec pi --no-skills "$@"
}

main "$@"
