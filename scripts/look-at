#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: look-at path [--objective text] [--context text]

Analyze a local PDF or image with gpt-5.4.

Arguments:
  path              Primary file path, relative or absolute

Options:
  --objective       Optional targeted extraction goal
  --context         Optional broader background
  -h, --help        Show this help

Examples:
  look-at path/to/file.pdf
  look-at path/to/file.pdf --objective "Extract the total due and due date"
  look-at path/to/image.png --objective "Describe the key visual details" --context "I need a quick summary"
EOF
}

fail() {
  echo "$*" >&2
  exit 1
}

cleanup() {
  [[ ${#temp_dirs[@]} -eq 0 ]] || rm -rf "${temp_dirs[@]}"
}

resolve_file() {
  local input="$1"

  [[ -e "$input" ]] || fail "File does not exist: $input"
  [[ ! -d "$input" ]] || fail "Path must be a file, not a directory: $input"

  realpath "$input"
}

mime_type() {
  file --brief --mime-type --dereference "$1"
}

render_pdf_to_images() {
  local pdf_path="$1"
  local output_dir="$2"

  uv run --with pymupdf python - "$pdf_path" "$output_dir" <<'PY'
import sys
from pathlib import Path

import fitz

pdf_path = Path(sys.argv[1])
out_dir = Path(sys.argv[2])
out_dir.mkdir(parents=True, exist_ok=True)

doc = fitz.open(pdf_path)
for index, page in enumerate(doc, start=1):
    pix = page.get_pixmap(matrix=fitz.Matrix(2, 2), alpha=False)
    pix.save(out_dir / f"page-{index:03d}.png")
PY
}

register_file_for_analysis() {
  local role="$1"
  local absolute_path="$2"

  case "$(mime_type "$absolute_path")" in
    image/png|image/jpeg|image/gif|image/webp)
      attachments+=("@$absolute_path")
      file_handling_summary+="- ${role}: ${absolute_path} attached as image"$'\n'
      ;;
    application/pdf)
      local render_dir
      local rendered_pages=0

      render_dir="$(mktemp -d)"
      temp_dirs+=("$render_dir")
      render_pdf_to_images "$absolute_path" "$render_dir"

      while IFS= read -r rendered_page; do
        attachments+=("@$rendered_page")
        rendered_pages=$((rendered_pages + 1))
      done < <(find "$render_dir" -maxdepth 1 -type f -name 'page-*.png' | sort)

      [[ $rendered_pages -gt 0 ]] || fail "Failed to render PDF pages for: ${absolute_path}"
      file_handling_summary+="- ${role}: ${absolute_path} rendered from PDF to ${rendered_pages} PNG page image(s)"$'\n'
      ;;
    text/*|application/json|application/xml|application/yaml|application/x-yaml)
      fail "Unsupported file type for look-at: ${absolute_path}. Use read for plain text or structured text files."
      ;;
    *)
      fail "Unsupported file type for look-at: ${absolute_path}. Supported: png/jpeg/gif/webp images and PDFs rendered to images."
      ;;
  esac
}

declare -a attachments=()
declare -a temp_dirs=()
file_handling_summary=""
system_prompt="Extract the minimum useful insight from local files. Focus on the objective, avoid transcription-by-default, and state uncertainty clearly."
default_objective="Summarize the file and extract the most relevant details."
default_context="No additional context was provided. Focus on the most useful details and keep the response concise."

main() {
  local path objective context prompt

  trap cleanup EXIT

  [[ $# -gt 0 ]] || {
    usage >&2
    exit 1
  }

  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -*)
      usage >&2
      fail "Unknown option: $1"
      ;;
  esac

  path="$1"
  objective=""
  context=""
  shift

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --objective)
        [[ $# -ge 2 ]] || fail "Missing value for --objective"
        [[ -z "$objective" ]] || fail "Objective provided more than once"
        objective="$2"
        shift 2
        ;;
      --context)
        [[ $# -ge 2 ]] || fail "Missing value for --context"
        [[ -z "$context" ]] || fail "Context provided more than once"
        context="$2"
        shift 2
        ;;
      -h|--help)
        usage
        exit 0
        ;;
      -*)
        usage >&2
        fail "Unknown option: $1"
        ;;
      *)
        fail "Unexpected argument: $1"
        ;;
    esac
  done

  path="$(resolve_file "$path")"
  objective="${objective:-$default_objective}"
  context="${context:-$default_context}"

  attachments=()
  temp_dirs=()
  file_handling_summary=""

  register_file_for_analysis "primary" "$path"

  prompt=$(
    cat <<EOF
Analyze the attached local file according to the objective below.

Primary file: ${path}
Objective: ${objective}
Context: ${context}

File handling:
${file_handling_summary}Requirements:
- Extract or summarize only the information relevant to the objective.
- Do not reproduce the entire file contents unless the objective explicitly asks for that.
- If the file is visual, describe the relevant visual details.
- If the file is unclear, unreadable, or ambiguous, say so explicitly.
- Keep the response concise and well structured.
EOF
  )

  pi --model openai-codex/gpt-5.4 --thinking low --no-session --no-tools --system-prompt "$system_prompt" -p "${attachments[@]}" "$prompt"
}

main "$@"
