#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Search the web and print concise, cited results.

Examples:
  web-search best cli design guidelines
  web-search -m gpt-5.3-codex-spark -t medium "sqlite json functions examples"

Usage:
  web-search [options] <query>

Options:
  -m, --model <model>             Codex model to use
  -t, --thinking <effort>         Reasoning effort: low, medium, high, xhigh
  -h, --help                      Show this help
EOF
}

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 1
fi

model=""
thinking=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      usage
      exit 0
      ;;
    -m|--model)
      [[ $# -ge 2 ]] || { echo "web-search: missing value for $1" >&2; exit 1; }
      model="$2"
      shift 2
      ;;
    -t|--thinking|--reasoning-effort)
      [[ $# -ge 2 ]] || { echo "web-search: missing value for $1" >&2; exit 1; }
      thinking="$2"
      shift 2
      ;;
    --)
      shift
      break
      ;;
    -*)
      echo "web-search: unknown option: $1" >&2
      usage >&2
      exit 1
      ;;
    *)
      break
      ;;
  esac
done

if [[ $# -eq 0 ]]; then
  usage >&2
  exit 1
fi

case "$thinking" in
  ""|low|medium|high|xhigh) ;;
  *)
    echo "web-search: invalid thinking effort: $thinking" >&2
    exit 1
    ;;
esac

query="$*"
out="$(mktemp)"
err="$(mktemp)"
trap 'rm -f "$out" "$err"' EXIT

codex_args=(
  --search
  --ask-for-approval never
  exec
  --skip-git-repo-check
  --ephemeral
  --sandbox read-only
  --color never
  --output-last-message "$out"
)

if [[ -n "$model" ]]; then
  codex_args=( -m "$model" "${codex_args[@]}" )
fi

if [[ -n "$thinking" ]]; then
  codex_args+=( -c "model_reasoning_effort=\"$thinking\"" )
fi

if ! codex "${codex_args[@]}" \
  "Search the web for: ${query}

Return 5-8 high-quality results. For each result include:
- title
- URL
- one short note

End with a 2-3 sentence summary. Keep it concise." \
  > /dev/null 2> "$err" < /dev/null; then
  cat "$err" >&2
  exit 1
fi

cat "$out"
