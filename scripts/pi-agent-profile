#!/usr/bin/env python3
import argparse
import os
import re
import shlex
import sys
from pathlib import Path
from urllib.error import HTTPError, URLError
from urllib.parse import urlparse
from urllib.request import Request, urlopen

ALLOWED_KEYS = {
    "model",
    "tools",
    "skills",
    "extensions",
    "flags",
    "thinking",
    "append-system-prompt",
    "name",
    "description",
}
LIST_KEYS = {"tools", "skills", "extensions"}
NON_EMPTY_TEXT_KEYS = {"model", "thinking"}
ISOLATION_FLAGS = ["--no-context-files", "--no-prompt-templates"]
FLAG_NAME_RE = re.compile(r"^[A-Za-z0-9][A-Za-z0-9_-]*$")

FlagValue = str | bool
FrontmatterValue = str | list[str] | bool | dict[str, FlagValue]
FrontmatterData = dict[str, FrontmatterValue]
ResourceItems = list[str] | None


class UsageError(Exception):
    pass


def parse_cli(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog="pi-agent-profile",
        usage=(
            "%(prog)s [--dry-run] <profile.md|name|url> "
            "[pi args/messages...]"
        ),
        description=(
            "Run Pi with an isolated Markdown profile. Profile URLs must use "
            "http(s) and end in .md."
        ),
    )
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("profile", nargs="?", metavar="profile.md|name|url")
    parser.add_argument(
        "passthrough", nargs=argparse.REMAINDER, metavar="pi args/messages"
    )

    args = parser.parse_args(argv)
    if args.profile is None:
        parser.error("missing profile")
    return args


def agent_dirs(cwd: Path) -> list[Path]:
    return [p / ".pi" / "agents" for p in (cwd, *cwd.parents)] + [
        Path.home() / ".pi" / "agent" / "agents"
    ]


def resolve_profile(value: str, cwd: Path) -> str | Path:
    if looks_like_url(value):
        validate_profile_url(value)
        return value

    if looks_like_path(value):
        path = Path(value).expanduser()
        if not path.is_absolute():
            path = cwd / path
        if path.is_file():
            return path.resolve()
        raise UsageError(f"profile file not found: {path}")

    name = value.removesuffix(".md").lower()
    for directory in agent_dirs(cwd):
        path = directory / f"{name}.md"
        if path.is_file():
            return path.resolve()
    raise UsageError(f"profile not found: {value}")


def load_profile(profile: str | Path) -> tuple[FrontmatterData, str]:
    text = read_profile_text(profile).removeprefix("\ufeff")
    if not text.startswith("---\n"):
        return {}, text.strip()

    try:
        end = text.index("\n---", 4)
    except ValueError:
        raise UsageError(f"{profile}: missing closing frontmatter delimiter")

    frontmatter = text[4:end]
    body = text[end + 4 :].lstrip("\n")
    return parse_frontmatter(profile, frontmatter), body.strip()


def read_profile_text(profile: str | Path) -> str:
    if isinstance(profile, Path):
        return profile.read_text(encoding="utf-8")

    request = Request(profile, headers={"User-Agent": "pi-agent-profile"})
    try:
        with urlopen(request, timeout=15) as response:
            content_type = response.headers.get_content_charset() or "utf-8"
            return response.read().decode(content_type)
    except HTTPError as error:
        raise UsageError(f"{profile}: HTTP {error.code}")
    except URLError as error:
        raise UsageError(f"{profile}: {error.reason}")
    except UnicodeDecodeError:
        raise UsageError(f"{profile}: response is not valid text")


def parse_frontmatter(path: str | Path, frontmatter: str) -> FrontmatterData:
    data: FrontmatterData = {}
    lines = frontmatter.splitlines()
    i = 0

    while i < len(lines):
        number = i + 2
        raw = lines[i]
        line = raw.strip()
        if not line or line.startswith("#"):
            i += 1
            continue

        if ":" not in line:
            raise UsageError(f"{path}:{number}: expected 'key: value'")

        key, _, raw_value = line.partition(":")
        key = key.strip()
        value = unquote(raw_value.strip())
        if key not in ALLOWED_KEYS:
            raise UsageError(f"{path}:{number}: unsupported key: {key}")
        if key in data:
            raise UsageError(f"{path}:{number}: duplicate key: {key}")

        if key == "append-system-prompt":
            data[key] = parse_bool(path, number, key, value)
            i += 1
        elif key == "tools" and value.lower() in {"true", "false"}:
            data[key] = parse_bool(path, number, key, value)
            i += 1
        elif key == "flags":
            if value:
                raise UsageError(f"{path}:{number}: expected nested map for {key}")
            data[key], i = parse_yaml_map(path, lines, i + 1, key)
        elif key in LIST_KEYS and not value:
            data[key], i = parse_yaml_list(path, lines, i + 1, key)
        else:
            if key in NON_EMPTY_TEXT_KEYS and not value:
                raise UsageError(f"{path}:{number}: empty value for {key}")
            data[key] = value
            i += 1

    return data


def parse_yaml_list(
    path: str | Path, lines: list[str], start: int, key: str
) -> tuple[list[str], int]:
    items = []
    rows, i = parse_indented(path, lines, start, key)
    for number, line in rows:
        if not line.startswith("-"):
            raise UsageError(f"{path}:{number}: expected '- value' for {key}")

        item = unquote(line[1:].strip())
        if not item:
            raise UsageError(f"{path}:{number}: empty list item for {key}")
        items.append(item)

    return items, i


def parse_yaml_map(
    path: str | Path, lines: list[str], start: int, key: str
) -> tuple[dict[str, FlagValue], int]:
    items: dict[str, FlagValue] = {}
    rows, i = parse_indented(path, lines, start, key)
    for number, line in rows:
        if ":" not in line:
            raise UsageError(f"{path}:{number}: expected 'name: value' for {key}")

        item_key, _, raw_value = line.partition(":")
        item_key = item_key.strip()
        if not FLAG_NAME_RE.fullmatch(item_key):
            raise UsageError(f"{path}:{number}: invalid flag name: {item_key}")
        if item_key in items:
            raise UsageError(f"{path}:{number}: duplicate flag: {item_key}")
        items[item_key] = parse_flag_value(path, number, item_key, raw_value.strip())
    return items, i


def parse_indented(
    path: str | Path, lines: list[str], start: int, key: str
) -> tuple[list[tuple[int, str]], int]:
    rows: list[tuple[int, str]] = []
    i = start

    while i < len(lines):
        number = i + 2
        raw = lines[i]
        line = raw.strip()
        if not line or line.startswith("#"):
            i += 1
            continue
        if not raw.startswith((" ", "\t")):
            break
        rows.append((number, line))
        i += 1

    if not rows:
        raise UsageError(
            f"{path}:{start + 2}: expected at least one nested item for {key}"
        )
    return rows, i


def parse_flag_value(
    path: str | Path, number: int, name: str, raw_value: str
) -> FlagValue:
    if not raw_value:
        raise UsageError(f"{path}:{number}: empty value for flag: {name}")
    if raw_value.lower() == "true":
        return True
    if raw_value.lower() == "false":
        raise UsageError(f"{path}:{number}: false is not supported for flag: {name}")
    return unquote(raw_value)


def unquote(value: str) -> str:
    if len(value) >= 2 and value[0] == value[-1] and value[0] in "'\"":
        return value[1:-1]
    return value


def parse_bool(path: str | Path, number: int, key: str, value: str) -> bool:
    if not value:
        raise UsageError(f"{path}:{number}: empty value for {key}")
    if value.lower() == "true":
        return True
    if value.lower() == "false":
        return False
    raise UsageError(f"{path}:{number}: expected true or false for {key}")


def typed_value(data: FrontmatterData, key: str, kind, default=None):
    value = data.get(key)
    if value is None:
        return default
    if not isinstance(value, kind):
        expected = "true or false" if kind is bool else "text value"
        raise UsageError(f"{key}: expected {expected}")
    return value


def tools_flags(value: FrontmatterValue | None) -> list[str]:
    if value is None or value is True:
        return []
    if value is False:
        return ["--no-tools"]
    return ["--tools", ",".join(parse_list_field("tools", value))]


def resource_items(value: FrontmatterValue | None, key: str) -> ResourceItems:
    if value is None:
        return []
    if isinstance(value, str) and value.strip() == "inherit":
        return None

    items = parse_list_field(key, value)
    if "inherit" in items:
        raise UsageError(f"{key}: inherit cannot be combined with explicit values")
    return items


def parse_list_field(key: str, value: FrontmatterValue) -> list[str]:
    if isinstance(value, str):
        items = value.split(",")
    elif isinstance(value, list):
        items = value
    else:
        raise UsageError(f"{key}: expected text or list value")

    items = [item.strip() for item in items if item.strip()]
    if not items:
        raise UsageError(f"{key}: expected at least one comma-separated value")
    return items


def pi_command(profile_source: str | Path, passthrough: list[str]) -> list[str]:
    data, prompt = load_profile(profile_source)
    base_dir = profile_source.parent if isinstance(profile_source, Path) else None
    command = ["pi", *ISOLATION_FLAGS]
    command += resource_flags(
        resource_items(data.get("skills"), "skills"),
        "--no-skills",
        "--skill",
        lambda item: resolve_skill(item, base_dir),
    )
    command += resource_flags(
        resource_items(data.get("extensions"), "extensions"),
        "--no-extensions",
        "--extension",
        lambda item: resolve_resource_path(item, base_dir),
    )

    for key, flag in (("model", "--model"), ("thinking", "--thinking")):
        if value := typed_value(data, key, str):
            command += [flag, value]

    command += tools_flags(data.get("tools"))
    command += custom_flags(data.get("flags"), base_dir)

    if prompt:
        prompt_flag = (
            "--append-system-prompt"
            if typed_value(data, "append-system-prompt", bool, False)
            else "--system-prompt"
        )
        command += [prompt_flag, prompt]

    return command + passthrough


def resource_flags(
    items: ResourceItems,
    no_flag: str,
    item_flag: str,
    resolve_item,
) -> list[str]:
    if items is None:
        return []

    flags = [no_flag]
    for item in items:
        flags.extend((item_flag, resolve_item(item)))
    return flags


def custom_flags(value: FrontmatterValue | None, base_dir: Path | None) -> list[str]:
    if value is None:
        return []
    if not isinstance(value, dict):
        raise UsageError("flags: expected map")

    flags: list[str] = []
    for name, flag_value in value.items():
        if flag_value is True:
            flags.append(f"--{name}")
        elif isinstance(flag_value, str):
            flags.append(f"--{name}={resolve_flag_value(flag_value, base_dir)}")
        else:
            raise UsageError(f"flags: unsupported value for {name}")
    return flags


def resolve_flag_value(value: str, base_dir: Path | None) -> str:
    if not value.startswith(("~", "/", "./", "../")):
        return value
    return resolve_path_value(value, base_dir)


def resolve_resource_path(value: str, base_dir: Path | None) -> str:
    if not is_local_path(value):
        return value
    return resolve_path_value(value, base_dir)


def resolve_path_value(value: str, base_dir: Path | None) -> str:
    path = Path(value).expanduser()
    if path.is_absolute():
        return str(path)
    if base_dir is None:
        raise UsageError(f"relative path requires a local profile: {value}")
    return str((base_dir / path).resolve())


def resolve_skill(value: str, base_dir: Path | None) -> str:
    if looks_like_path(value):
        resolved = Path(resolve_path_value(value, base_dir))
    else:
        resolved = Path.home() / ".agents" / "skills" / value

    if not resolved.exists():
        raise UsageError(f"skills: skill not found: {value}")
    return str(resolved)


def is_local_path(value: str) -> bool:
    return (
        not value.startswith(("npm:", "git:", "ssh://"))
        and not looks_like_url(value)
        and looks_like_path(value)
    )


def looks_like_path(value: str) -> bool:
    return value.startswith(("~", ".", "/")) or "/" in value or value.endswith(".md")


def looks_like_url(value: str) -> bool:
    return urlparse(value).scheme in {"http", "https"}


def validate_profile_url(value: str) -> None:
    parsed = urlparse(value)
    if parsed.scheme not in {"http", "https"} or not parsed.netloc:
        raise UsageError(f"invalid profile URL: {value}")
    if not parsed.path.endswith(".md"):
        raise UsageError(f"profile URL must end in .md: {value}")


def run_command(command: list[str], dry_run: bool) -> None:
    if dry_run:
        print(shlex.join(command))
        return

    os.execvp(command[0], command)


def main(argv: list[str]) -> int:
    try:
        args = parse_cli(argv)
        cwd = Path.cwd()

        assert args.profile is not None
        command = pi_command(resolve_profile(args.profile, cwd), args.passthrough)
        run_command(command, args.dry_run)
        return 0
    except UsageError as error:
        print(
            f"pi-agent-profile: {error}\nTry 'pi-agent-profile --help'.",
            file=sys.stderr,
        )
        return 2
    except FileNotFoundError as error:
        print(f"pi-agent-profile: command not found: {error.filename}", file=sys.stderr)
        return 127


if __name__ == "__main__":
    raise SystemExit(main(sys.argv[1:]))
