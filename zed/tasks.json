[
  {
    "label": "Open External Terminal",
    "command": "setsid",
    "args": [
      "-f",
      "ghostty",
      "+new-window",
      "--working-directory=$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "never",
    "hide": "always",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "show_summary": false,
    "show_command": false
  },
  {
    "label": "pi",
    "command": "setsid",
    "args": [
      "-f",
      "ghostty",
      "+new-window",
      "--working-directory=$ZED_WORKTREE_ROOT",
      "-e",
      "pi"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "never",
    "hide": "always",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "show_summary": false,
    "show_command": false
  },
  {
    "label": "Generate Commit and Push",
    "command": "setsid",
    "args": [
      "-f",
      "bash",
      "-lc",
      "mkdir -p \"$HOME/.cache\" && cd \"$1\" && pi -p 'make atomic commits and push' --model openai-codex/gpt-5.3-codex-spark >>\"$HOME/.cache/zed-pi-commit.log\" 2>&1",
      "bash",
      "$ZED_WORKTREE_ROOT"
    ],
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "never",
    "hide": "always",
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "show_summary": false,
    "show_command": false,
    "save": "all"
  }
]
