[
  {
    "label": "Open External Terminal",
    "command": "setsid -f alacritty --working-directory \"$ZED_WORKTREE_ROOT\" >/dev/null 2>&1",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "never",
    "hide": "always"
  },
  {
    "label": "pi",
    "command": "setsid -f alacritty -e pi >/dev/null 2>&1",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "never",
    "hide": "always"
  },
  {
    "label": "Generate Commit and Push",
    "command": "pi -p \"make atomic commits and push\" --model openai-codex/gpt-5.3-codex-spark",
    "cwd": "$ZED_WORKTREE_ROOT",
    "reveal": "no_focus",
    "hide": "on_success"
  }
]
